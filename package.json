{
  "name": "local-kubernetes-cluster-demo",
  "version": "0.0.0-development",
  "private": true,
  "scripts": {
    "check:yaml": "yamllint -c .yamllint kind-cluster k3d-cluster",
    "check:helm": "helm lint kind-cluster/k8s-demo && helm lint kind-cluster/cluster-gateway && helm lint k3d-cluster/api-demo",
    "check:local": "npm run check:yaml && npm run check:helm"
  },
  "release": {
    "branches": ["main"],
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "preset": "conventionalcommits"
        }
      ],
      [
        "@semantic-release/release-notes-generator",
        {
          "preset": "conventionalcommits"
        }
      ],
      "@semantic-release/github"
    ]
  }
}
